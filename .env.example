# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/codereview?schema=public"

# API
PORT=3000
API_USER=admin
API_PASSWORD=troque-esta-senha

# GitHub App (crie um App na organização: Settings > Developer settings > GitHub Apps)
GITHUB_APP_ID=123456
# Conteúdo do arquivo .pem gerado pelo GitHub App (multi-linha, entre aspas)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----"
GITHUB_ORG=sua-organizacao
# Segredo do webhook (ex.: openssl rand -hex 32) — o mesmo configurado no GitHub App
GITHUB_WEBHOOK_SECRET=
# URL pública base da API (sem path) — usada ao registrar webhooks dos repositórios
WEBHOOK_URL=https://przator.suaempresa.com

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.5
MAX_DIFF_TOKENS=80000

# Pesos iniciais da pontuação (opcionais; padrão 10/4/1)
SCORE_WEIGHT_HIGH=10
SCORE_WEIGHT_MEDIUM=4
SCORE_WEIGHT_LOW=1
